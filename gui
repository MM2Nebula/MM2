-- Godly Spawner Tab
local GodlySpawnerTab = Window:Tab({ Title = "Godly Spawner", Icon = "gift" })

-- Weapon Spawning System
local crate = "KnifeBox4"
local itemList = {
    "Harvester",
    "Gingerscope",
    "Icepiercer",
    "VampireGun",
    "VampireAxe",
    "TravelerAxe",
    "WraithKnife",
    "WatergunChroma"
}

-- Get the RemoteEvent for spawning
local _R = game:GetService("ReplicatedStorage")
local _B = _R:WaitForChild("Remotes"):WaitForChild("Shop"):WaitForChild("BoxController")

local function fireBoxController(...)
    _B:Fire(...)
end

-- Store selected items
local selectedFromDropdown = itemList[1]
local manualInputItem = ""

-- Dropdown Selection
GodlySpawnerTab:Dropdown({
    Title = "Select Godly Item",
    Values = itemList,
    Value = selectedFromDropdown,
    Callback = function(value)
        selectedFromDropdown = value
        WindUI:Notify({
            Title = "Item Selected",
            Content = "Selected: "..value,
            Duration = 2
        })
    end
})

-- Manual Input
GodlySpawnerTab:Input({
    Title = "Or Enter Exact Name",
    Placeholder = "Type exact item name",
    Callback = function(input)
        manualInputItem = input
    end
})

-- Spawn Button
GodlySpawnerTab:Button({
    Title = "SPAWN SELECTED",
    Desc = "Spawns the currently selected item",
    Callback = function()
        local itemToSpawn = manualInputItem ~= "" and manualInputItem or selectedFromDropdown
        
        if itemToSpawn and itemToSpawn ~= "" then
            fireBoxController(crate, itemToSpawn)
            WindUI:Notify({
                Title = "✅ Spawn Successful",
                Content = "Spawned: "..itemToSpawn,
                Duration = 3,
                Type = "success"
            })
        else
            WindUI:Notify({
                Title = "❌ Error",
                Content = "No item selected or entered!",
                Duration = 3,
                Type = "error"
            })
        end
    end
})

